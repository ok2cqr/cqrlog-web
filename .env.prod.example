PROD_APP_PORT=8080
PROD_APP_SECRET=replace-with-a-long-random-secret
PROD_DEFAULT_URI=http://localhost:8080
# Optional: leave empty when Apache2 in front of the app handles Basic Auth.
PROD_BASIC_AUTH_USERNAME=
PROD_BASIC_AUTH_PASSWORD=
PROD_DB_HOST=host.docker.internal
PROD_DB_PORT=13306
PROD_DB_NAME=cqrlog002
PROD_DB_USER=cqrlog
PROD_DB_PASSWORD=cqrlog
PROD_DB_CHARSET=utf8mb4
PROD_FRONTEND_RADIO_SYNC_DEFAULT_URL=https://example.com/radio-json.php
PROD_FRONTEND_RADIO_SYNC_DEFAULT_POLL_INTERVAL_SECONDS=2
