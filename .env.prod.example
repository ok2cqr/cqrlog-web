# Host port published by Docker for the app container.
APP_PORT=8080

# Symfony secret used for CSRF tokens and other security features.
# Generate with: php -r "echo bin2hex(random_bytes(16));"
APP_SECRET=replace-with-a-long-random-secret

# Public base URL of the app. Symfony uses it to generate absolute URLs
# outside a normal HTTP request (e.g. CLI commands).
DEFAULT_URI=http://localhost:8080

###> app/auth ###
# Credentials for the login form. Both must be set.
LOGIN_USERNAME=
LOGIN_PASSWORD=

# Server-side session idle timeout in seconds. The session expires after
# this many seconds of inactivity (no API calls). Set to 0 to disable.
# Example: 28800 = 8 hours, 3600 = 1 hour.
# SESSION_IDLE_TIMEOUT_SECONDS=28800
###< app/auth ###

# MariaDB connection. Point to the same database used by desktop CQRLOG.
DB_HOST=host.docker.internal
DB_PORT=13306
DB_NAME=cqrlog002
DB_USER=cqrlog
DB_PASSWORD=cqrlog
DB_CHARSET=utf8mb4

# Default radio sync endpoint (JSON API compatible with pico-radio-gateway).
# Leave empty or remove to disable radio sync by default.
FRONTEND_RADIO_SYNC_DEFAULT_URL=https://example.com/radio-json.php
FRONTEND_RADIO_SYNC_DEFAULT_POLL_INTERVAL_SECONDS=2
